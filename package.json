{
  "name": "earth-dynamics",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Wobblescope — time-synchronized Earth-system explorer (pole motion, quakes, space weather, orbits)",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "fetch-data": "node scripts/fetch-data.mjs",
    "fetch-heliocentric": "node scripts/fetch-heliocentric.mjs",
    "fetch-space-weather": "node scripts/fetch-space-weather.mjs",
    "build-plate-motion": "node scripts/build-plate-motion.mjs",
    "fetch-plate-steps": "node scripts/fetch-plate-steps.mjs",
    "build-igrf-fieldlines": "node scripts/build-igrf-fieldlines.mjs",
    "fetch-radar-sites": "node scripts/fetch-radar-sites.mjs",
    "fetch-earth-textures": "node scripts/fetch-earth-textures.mjs",
    "fetch-home-imagery": "node scripts/fetch-home-imagery.mjs",
    "fetch-home-terrain": "scripts/.venv/bin/python scripts/fetch-home-terrain.py",
    "fetch-home-terrain:setup": "python3 -m venv scripts/.venv && scripts/.venv/bin/pip install rasterio numpy pillow",
    "sync-home": "node scripts/sync-home-to-db.mjs",
    "ingest": "node ingest/run.mjs",
    "ingest:force": "node ingest/run.mjs --force",
    "api": "node api/server.mjs",
    "start": "concurrently \"npm run api\" \"npm run dev\""
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "geomagnetism": "^0.2.0",
    "geopack-ts": "^0.1.0",
    "three": "^0.175.0",
    "@imagemagick/magick-wasm": "0.0.41"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "geotiff": "^3.0.5",
    "sharp": "^0.33.5",
    "vite": "^6.2.0"
  }
}
